---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../../config/site.json';

// 1. 安全抓取所有新聞檔案 
const allNewsFiles = await Astro.glob('../content/news/*.md');

// 2. 處理資料並加入防錯機制
const news = allNewsFiles.map(m => {
  const { title, date } = m.frontmatter;
  const raw = m.rawContent() || "";
  
  // 移除 Markdown 標頭，只取正文作為摘要
  const cleanContent = raw.replace(/---[\s\S]*?---/, '').trim();
  const excerpt = cleanContent ? cleanContent.slice(0, 100) + '...' : "點擊查看詳情...";

  // 修正點：使用 m.file 取代 m.id 來取得檔名 
  const fileName = m.file.split('/').pop().replace('.md', '');

  return {
    title: title || "未命名文章",
    date: date || "2026-01-01", 
    slug: fileName,
    excerpt: excerpt
  };
});

// 3. 安全排序
news.sort((a, b) => {
  const dateA = new Date(a.date).getTime();
  const dateB = new Date(b.date).getTime();
  return (isNaN(dateB) ? 0 : dateB) - (isNaN(dateA) ? 0 : dateA);
});
// src/pages/news.astro --- 區塊內
const base = import.meta.env.BASE_URL;
...
---

<BaseLayout title={`最新消息 - ${site.labNameEn}`}>
  <h1 style="color: var(--brand); margin-bottom: 8px;">最新消息</h1>
  <p class="meta">實驗室近期動態與活動紀錄。</p>

  <div style="margin-top: 24px; display: flex; flex-direction: column; gap: 16px;">
    {news.length > 0 ? (
      news.map(item => (
        <a class="card col12" href={`${base}/news/${item.slug}/`}> style="display: block; text-decoration: none; transition: 0.2s;">
          <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; flex-wrap: wrap;">
            <h2 style="margin: 0; font-size: 19px; color: var(--brand); flex: 1;">{item.title}</h2>
            <span class="meta" style="white-space: nowrap; background: var(--bg); padding: 2px 8px; border-radius: 4px;">
              📅 {item.date}
            </span>
          </div>
          <p style="margin: 12px 0 0; font-size: 14px; color: var(--muted); line-height: 1.6;">
            {item.excerpt}
          </p>
          <div style="margin-top: 10px; font-size: 13px; color: var(--brand2); font-weight: 600;">
            閱讀全文 →
          </div>
        </a>
      ))
    ) : (
      <p class="meta">目前尚無最新消息。</p>
    )}
  </div>
</BaseLayout>