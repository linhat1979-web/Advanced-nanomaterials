---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../../config/site.json';

// 1. 取得子目錄路徑，確保圖片在 GitHub Pages 正常顯示 [cite: 104]
const base = import.meta.env.BASE_URL;

// 2. 核心優化：自動抓取該資料夾下所有 Markdown 檔案 
const allEquipment = await Astro.glob('../content/equipment/*.md');

// 3. 自動排序與資料處理 
const equipmentList = allEquipment
  .sort((a, b) => (a.frontmatter.order || 99) - (b.frontmatter.order || 99))
  .map(item => {
    const raw = item.rawContent() || "";
    const cleanDescription = raw.replace(/---[\s\S]*?---/, '').trim();
    
    return {
      name: item.frontmatter.name,
      specs: item.frontmatter.specs,
      image: item.frontmatter.image.startsWith('http') ? item.frontmatter.image : `${base}${item.frontmatter.image}`,
      description: cleanDescription || "尚無詳細說明。"
    };
  });
---

<BaseLayout title={`研究設備 - ${site.labNameEn}`} description="實驗室儀器與設備說明">
  
  <link rel="stylesheet" href="https://unpkg.com/photoswipe@5.4.3/dist/photoswipe.css" />

  <div style="margin-bottom: 32px;">
    <h1 style="margin: 0 0 8px; color: var(--brand);">研究設備</h1>
    <p class="meta">點擊圖片可直接放大查看細節。</p>
  </div>

  <div class="grid" id="equipment-gallery">
    {equipmentList.map((item, index) => (
      <div class="card col6">
        <div class="equipmentCardContent">
          <a 
            href={item.image} 
            class="pswp-link" 
            data-pswp-width="1200" 
            data-pswp-height="900"
          >
            <div class="imageContainer">
              <img src={item.image} alt={item.name} class="equipmentImage" id={`img-${index}`} />
              <div class="zoomOverlay">🔍 點擊放大</div>
            </div>
          </a>
          
          <div class="equipmentText">
            <h2 style="margin: 0 0 8px; font-size: 20px;">{item.name}</h2>
            <div class="specsTag">{item.specs}</div>
            <p class="meta" style="line-height: 1.6; margin: 0; white-space: pre-wrap;">{item.description}</p>
          </div>
        </div>
      </div>
    ))}
  </div>

  <script>
    import PhotoSwipeLightbox from 'https://unpkg.com/photoswipe@5.4.3/dist/photoswipe-lightbox.esm.js';
    function initLightbox() {
      const lightbox = new PhotoSwipeLightbox({
        gallery: '#equipment-gallery',
        children: '.pswp-link',
        pswpModule: () => import('https://unpkg.com/photoswipe@5.4.3/dist/photoswipe.esm.js')
      });
      lightbox.on('gettingData', (event) => {
        const { data } = event;
        const img = data.element.querySelector('img');
        if (img && img.naturalWidth > 0) {
          data.width = img.naturalWidth;
          data.height = img.naturalHeight;
        }
      });
      lightbox.init();
    }
    initLightbox();
    document.addEventListener('astro:after-swap', initLightbox);
  </script>
</BaseLayout>

<style>
  .equipmentCardContent { display: flex; gap: 24px; align-items: flex-start; }
  .pswp-link { display: block; flex-shrink: 0; text-decoration: none; }
  .imageContainer {
    width: 140px; height: 140px; 
    background: var(--bg); border-radius: 16px; 
    overflow: hidden; border: 1px solid var(--border);
    position: relative; cursor: zoom-in; transition: all 0.3s ease;
  }
  .imageContainer:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.1); }
  .equipmentImage { width: 100%; height: 100%; object-fit: cover; }
  .zoomOverlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: rgba(139, 69, 19, 0.8); color: white; 
    font-size: 11px; text-align: center; padding: 4px 0; 
    opacity: 0; transition: opacity 0.3s;
  }
  .imageContainer:hover .zoomOverlay { opacity: 1; }
  .equipmentText { flex: 1; }
  .specsTag { 
    display: inline-block; background: rgba(139,69,19,0.1); color: var(--brand); 
    padding: 2px 10px; border-radius: 6px; font-size: 12px; 
    margin-bottom: 10px; font-weight: 600; 
  }
  @media (max-width: 600px) {
    .equipmentCardContent { flex-direction: column; align-items: center; text-align: center; }
  }
</style>