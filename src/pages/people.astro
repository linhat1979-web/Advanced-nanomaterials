---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../../config/site.json';

const allPeople = await Astro.glob('../content/people/*.md');
const categories = ["指導教授", "碩士班學生", "專題生", "已畢業成員"];
---

<BaseLayout title={`成員介紹 - ${site.labNameEn}`}>
  <h1 style="color: var(--brand); margin-bottom: 30px;">團隊成員</h1>

  {categories.map(cat => {
    const members = allPeople.filter(p => p.frontmatter.category === cat);
    if (members.length === 0) return null;
    return (
      <section style="margin-bottom: 40px;">
        <h2 style="border-left: 5px solid var(--brand); padding-left: 15px; margin-bottom: 20px;">{cat}</h2>
        <div class="grid">
          {members.map(m => (
            <div class="card col4" style="text-align: center;">
              <img src={m.frontmatter.avatar || '/images/people/default.jpg'} 
                   style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; margin-bottom: 15px; border: 3px solid var(--bg);" />
              <h3 style="margin: 5px 0;">{m.frontmatter.name}</h3>
              <p class="meta" style="margin-bottom: 10px;">{m.frontmatter.title}</p>
              <p style="font-size: 14px; color: var(--muted);">{m.frontmatter.email}</p>
            </div>
          ))}
        </div>
      </section>
    );
  })}
</BaseLayout>