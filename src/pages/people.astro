---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../../config/site.json';

// 自動抓取所有成員檔案 [cite: 101]
const allPeople = await Astro.glob('../content/people/*.md');

// 設定您想要的顯示順序，不在列表中的分類會自動排在最後面
const priorityOrder = ["指導教授", "碩士班學生", "專題生", "已畢業成員"];

// 自動從所有檔案中提取現有的分類 [cite: 102]
const existingCategories = [...new Set(allPeople.map(p => p.frontmatter.category))];

// 依照優先順序排列分類標籤
const categories = existingCategories.sort((a, b) => {
  let idxA = priorityOrder.indexOf(a);
  let idxB = priorityOrder.indexOf(b);
  return (idxA === -1 ? 99 : idxA) - (idxB === -1 ? 99 : idxB);
});
---

<BaseLayout title={`成員介紹 - ${site.labNameEn}`}>
  <h1 style="color: var(--brand); margin-bottom: 30px;">團隊成員</h1>

  {categories.map(cat => {
    const members = allPeople.filter(p => p.frontmatter.category === cat);
    if (members.length === 0) return null;
    return (
      <section style="margin-bottom: 40px;">
        <h2 style="border-left: 5px solid var(--brand); padding-left: 15px; margin-bottom: 20px; font-size: 24px;">{cat}</h2>
        <div class="grid">
          {members.map(m => (
            <div class="card col4" style="text-align: center; padding: 30px;">
              <img 
                src={m.frontmatter.avatar || '/images/people/default.jpg'} 
                alt={m.frontmatter.name}
                style="width: 140px; height: 140px; border-radius: 50%; object-fit: cover; margin-bottom: 20px; border: 4px solid white; box-shadow: var(--shadow);" 
              /> [cite: 103]
              <h3 style="margin: 0 0 5px; font-size: 20px;">{m.frontmatter.name}</h3>
              <p class="meta" style="margin-bottom: 12px; color: var(--brand); font-weight: 600;">{m.frontmatter.title}</p>
              <div style="font-size: 13px; color: var(--muted); border-top: 1px solid var(--border); padding-top: 10px;">
                {m.frontmatter.email} [cite: 104, 105]
              </div>
            </div>
          ))}
        </div>
      </section>
    );
  })}
</BaseLayout>