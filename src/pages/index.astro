---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../../config/site.json';

const heroImages = [
  '/images/hero/1.jpg',
  '/images/hero/2.jpg',
  '/images/hero/3.jpg'
];

const labName = site.labNameZh;
---

<BaseLayout title={site.labNameEn} description="Advanced Nanomaterials Laboratory">
  <section class="hero">
    <div class="heroInner">
      <div class="heroImg" id="heroImg" style="background-image:url('${heroImages[0]}')"></div>
      <div class="heroText">
        <h1>{site.labNameZh}</h1>
        <p>
          我們專注於功能性發光奈米材料（碳量子點與金屬奈米材料）的製備、性質鑑定與應用研究。
        </p>
        <div style="margin-top:18px; display:flex; gap:10px; flex-wrap:wrap">
          <a class="btn btnPrimary" href="/research">探索研究方向</a>
          <a class="btn" href="/news">查看最新消息</a>
        </div>
      </div>
    </div>
  </section>

  <section style="margin-top:18px">
    <div class="grid">
      <div class="card col3" style="grid-column:span 3"></div>
      <div class="card col6" style="grid-column:span 6">
        <h2>特色概覽</h2>
        <div class="meta">研究 • 成員 • 設備 • 發表 • 最新消息</div>
      </div>
      <div class="card col6" style="grid-column:span 6">
        <h2>指導教授</h2>
        <div class="meta">{site.advisorNameZh}</div>
      </div>
    </div>
  </section>

  <section style="margin-top:18px">
    <div class="grid">
      <div class="card col4" style="grid-column:span 4">
        <h2>研究方向</h2>
        <p class="meta">研究主題與團隊成果摘要</p>
        <a class="btn" href="/research">進入 →</a>
      </div>
      <div class="card col4" style="grid-column:span 4">
        <h2>研究設備</h2>
        <p class="meta">儀器列表與能力說明</p>
        <a class="btn" href="/equipment">進入 →</a>
      </div>
      <div class="card col4" style="grid-column:span 4">
        <h2>期刊發表</h2>
        <p class="meta">論文/期刊與連結</p>
        <a class="btn" href="/publications">進入 →</a>
      </div>
    </div>
  </section>

  <script>
    const images = {heroImages};
  </script>

  <script>
    const imgs = {heroImages};
    const el = document.getElementById('heroImg');
    let i = 0;
    setInterval(()=>{
      if(!el) return;
      i = (i+1) % imgs.length;
      el.style.backgroundImage = 'url(' + imgs[i] + ')';
    }, 4000);
  </script>
</BaseLayout>
