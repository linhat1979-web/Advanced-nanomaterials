---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../../config/site.json';

// 抓取最新一則消息作為首頁顯示（選用）
const allNews = await Astro.glob('../content/news/*.md');
const latestNews = allNews
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime())
  .slice(0, 1);
---

<BaseLayout title={site.labNameEn}>
  
  <section class="hero-section">
    <h1>{site.labNameEn}</h1>
    <p class="hero-subtitle">
      先進奈米材料研究室：專注於碳量子點 (Carbon Dots) 的合成、純化及其光學特性研究。
    </p>
  </section>

  <div class="grid">
    <div class="card col6">
      <h2 style="color: var(--brand);">關於本實驗室</h2>
      <p style="line-height: 1.8;">
        本研究室結合化學合成、光譜分析與材料工程。核心技術包含：碳點 (CDs) 螢光機制研究、金屬有機框架 (MOFs) 複合材料開發、以及環境感測應用。
      </p>
    </div>

    <div class="card col6 professor-card">
      <div class="avatar-placeholder">Photo</div>
      <div>
        <h2 style="margin: 0; font-size: 24px;">張老師 博士 <small>Advisor</small></h2>
        <p style="margin: 8px 0; font-size: 15px;">國立彰化師範大學 化學系 教授</p>
        <a href="mailto:cwchang@cc.ncue.edu.tw" class="email-link">✉️ 聯絡教授</a>
      </div>
    </div>
  </div>

  <div class="feature-container">
    
    <div class="feature-item">
      <div class="feature-content">
        <div class="feature-icon">🔬</div>
        <h3>研究方向</h3>
        <p>聚焦碳點 (CDs) 合成、純化與螢光猝滅機制研究。</p>
      </div>
      <a href="/research" class="feature-btn">進入探索 →</a>
    </div>

    <div class="feature-item">
      <div class="feature-content">
        <div class="feature-icon">🛠️</div>
        <h3>研究設備</h3>
        <p>先進光譜儀、電化學分析儀與材料製備設備清單。</p>
      </div>
      <a href="/Advanced-nanomaterials/equipment" class="feature-btn">查看儀器 →</a>
    </div>

    <div class="feature-item">
      <div class="feature-content">
        <div class="feature-icon">📝</div>
        <h3>期刊發表</h3>
        <p>收錄包含 JPCC 等國際頂尖期刊之最新研究成果。</p>
      </div>
      <a href="/Advanced-nanomaterials／publications" class="feature-btn">查看發表 →</a>
    </div>

  </div>

</BaseLayout>

<style>
  /* Hero 樣式 */
  .hero-section {
    padding: 80px 0 60px;
    text-align: center;
    background: linear-gradient(to bottom, var(--bg), #fdfcfb);
  }
  .hero-section h1 {
    font-size: 3rem;
    color: var(--brand);
    margin-bottom: 16px;
  }
  .hero-subtitle {
    font-size: 1.2rem;
    color: var(--muted);
    max-width: 800px;
    margin: 0 auto;
  }

  /* 教授卡片樣式 */
  .professor-card {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .avatar-placeholder {
    width: 90px;
    height: 90px;
    background: #f0f0f0;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    color: #aaa;
    flex-shrink: 0;
  }
  .email-link {
    font-size: 14px;
    color: var(--brand2);
    font-weight: 600;
    text-decoration: none;
  }

  /* --- 三個物件並排的核心 CSS --- */
  .feature-container {
    display: flex;
    gap: 24px;              /* 物件間距 */
    margin-top: 40px;
    align-items: stretch;   /* 強制所有卡片高度相等 */
    width: 100%;
  }

  .feature-item {
    flex: 1;                /* 每個物件寬度各佔 1/3 */
    background: white;
    padding: 40px 30px;
    border-radius: 20px;
    border: 1px solid var(--border);
    box-shadow: 0 4px 6px rgba(0,0,0,0.02);
    
    /* 內部按鈕對齊邏輯 */
    display: flex;
    flex-direction: column;
    justify-content: space-between; 
    align-items: center;
    text-align: center;
    transition: transform 0.3s ease;
  }

  .feature-item:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.06);
  }

  .feature-content {
    width: 100%;
  }

  .feature-icon {
    font-size: 40px;
    margin-bottom: 20px;
  }

  .feature-item h3 {
    font-size: 22px;
    margin-bottom: 15px;
    color: var(--text);
  }

  .feature-item p {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.6;
    margin-bottom: 30px;
  }

  .feature-btn {
    width: 100%;
    max-width: 180px;       /* 限制按鈕寬度，更精緻 */
    padding: 12px;
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    color: var(--text);
    font-weight: 600;
    font-size: 14px;
    transition: all 0.2s;
    background: white;
  }

  .feature-btn:hover {
    background: var(--brand);
    color: white !important;
    border-color: var(--brand);
  }

  /* 手機版適應：當螢幕寬度小於 800px 時改為垂直排列 */
  @media (max-width: 800px) {
    .feature-container {
      flex-direction: column;
    }
    .feature-item {
      width: 100%;
    }
  }
</style>