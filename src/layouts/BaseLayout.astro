---
// 從 Astro props 取得標題與描述，若無則使用預設值
const { title = 'Advanced Nanomaterials Laboratory', description = 'Laboratory website' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <link rel="icon" href={`${base}/favicon.svg`} />

    <style is:global>
      :root {
        --bg: #f8f5f2; /* 暖色調背景 */
        --card: #ffffff; /* 純白卡片 */
        --text: #2a1f18; /* 深褐色文字 */
        --muted: #6f5a4d; /* 柔和輔助文字 */
        --brand: #8b4513; /* 品牌主色 */
        --brand2: #d2691e; /* 品牌次色 */
        --border: rgba(123, 85, 55, 0.12);
        --shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: "PingFang TC", "Heiti TC", "Microsoft JhengHei", system-ui, -apple-system, sans-serif;
        background-color: var(--bg);
        color: var(--text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      a { color: inherit; text-decoration: none; transition: 0.3s; }

      header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(248, 245, 242, 0.85);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }

      .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

      nav { display: flex; align-items: center; justify-content: space-between; padding: 18px 0; }
      
      .brand { display: flex; flex-direction: column; line-height: 1.2; }
      .brand strong { font-size: 1.2rem; letter-spacing: 0.5px; color: var(--brand); }
      .brand span { font-size: 12px; color: var(--muted); }

      .links { display: flex; gap: 24px; align-items: center; }
      .links a { font-size: 15px; color: var(--muted); font-weight: 500; }
      .links a:hover { color: var(--brand); }

      .pill {
        border: 1.5px solid var(--brand);
        padding: 8px 20px;
        border-radius: 999px;
        background: transparent;
        color: var(--brand) !important;
        font-weight: 600;
      }
      .pill:hover { background: var(--brand); color: white !important; }

      main { padding: 40px 0 80px; }

      .grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 24px; }
      .col12 { grid-column: span 12; }
      .col6 { grid-column: span 6; }
      .col4 { grid-column: span 4; }
      
      @media (max-width: 800px) { 
        nav { flex-direction: column; gap: 16px; text-align: center; }
        .links { flex-wrap: wrap; justify-content: center; gap: 12px; }
        .col6, .col4 { grid-column: span 12; } 
      }

      .card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 32px;
        box-shadow: var(--shadow);
        transition: 0.3s;
      }
      .card:hover { transform: translateY(-5px); box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08); }

      footer { border-top: 1px solid var(--border); padding: 40px 0; color: var(--muted); font-size: 14px; text-align: center; }
      
      /* 翻譯按鈕定位 */
      .translateBar { position: fixed; right: 24px; bottom: 24px; z-index: 100; }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <nav>
          <div class="brand">
            <strong>{title}</strong>
            <span>Lab website • multi-language</span>
          </div>
          <div class="links">
           <a href={`${base}/`}>首頁</a>
           <a href={`${base}/research`}>研究方向</a>
           <a href={`${base}/people`}>成員</a>
           <a href={`${base}/equipment`}>研究設備</a>
           <a href={`${base}/publications`}>期刊發表</a>
           <a href={`${base}/activities`}>實驗室活動</a>
           <a href={`${base}/news`}>最新消息</a>
           <a class="pill" href={`${base}/contact`}>聯絡我們</a>
          </div>
        </nav>
      </div>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <footer>
      <div class="container">
        <div style="text-align: center;">
          <div style="font-weight: 600; margin-bottom: 4px; color: var(--brand);">
            © {new Date().getFullYear()} Advanced Nanomaterials Laboratory
          </div>
          <div style="font-size: 12px; color: var(--muted);">
            最後更新時間：{
              new Intl.DateTimeFormat('zh-TW', {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit',
                hour: '2-digit',
                minute: '2-digit',
                hour12: false
              }).format(new Date())
            }
          </div>
        </div>
      </div>
    </footer>

    <div class="translateBar">
      <button id="translateBtn" class="pill" style="background: white; cursor: pointer; box-shadow: var(--shadow);">
        English
      </button>
    </div>

    <script>
      const btn = document.getElementById('translateBtn');
      let translated = false;

      async function translateElement(el) {
        const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null);
        let node;
        const textNodes = [];

        while (node = walker.nextNode()) {
          if (node.nodeValue.trim()) textNodes.push(node);
        }

        for (const node of textNodes) {
          try {
            const res = await fetch('https://translate.googleapis.com/translate_a/single?client=gtx&sl=zh-Hant&tl=en&dt=t&q=' + encodeURIComponent(node.nodeValue));
            const data = await res.json();
            let translatedText = '';
            for (const part of data[0]) translatedText += part[0];
            node.nodeValue = translatedText;
          } catch (e) {
            console.error('Node translation failed', e);
          }
        }
      }

      btn?.addEventListener('click', async () => {
        if (!translated) {
          btn.textContent = 'Translating...';
          btn.disabled = true;

          const regions = [document.querySelector('header'), document.querySelector('main'), document.querySelector('footer')];
          for (const region of regions) {
            if (region) await translateElement(region);
          }

          translated = true;
          btn.textContent = '中文';
          btn.disabled = false;
        } else {
          location.reload();
        }
      });
    </script>
  </body>
</html>